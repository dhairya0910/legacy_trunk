<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>CRUD Demo with MongoDB</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-100 flex justify-center items-center min-h-screen">

<div class="w-full max-w-md bg-white shadow-lg rounded-lg p-6">
  <h1 class="text-2xl font-bold text-center mb-4">CRUD Demo (MongoDB)</h1>

  <!-- CREATE -->
  <form action="/add" method="POST" class="flex gap-2 mb-4">
    <input type="text" name="item" placeholder="Enter item..." class="flex-grow border px-2 py-1 rounded" required />
    <button type="submit" class="bg-blue-500 text-white px-4 py-1 rounded">Add</button>
  </form>

  <!-- READ -->
  <ul class="space-y-2">
    <% items.forEach((item) => { %>
      <li class="flex justify-between items-center bg-gray-50 px-3 py-2 rounded">
        <span><%= item.name %></span>
        <div class="flex gap-2">
          <!-- UPDATE -->
          <form action="/edit/<%= item._id %>" method="POST" class="flex gap-2">
            <input type="text" name="newValue" placeholder="Edit..." class="border px-2 py-1 rounded"/>
            <button type="submit" class="bg-green-500 text-white px-3 py-1 rounded">Save</button>
          </form>

          <!-- DELETE -->
          <form action="/delete/<%= item._id %>" method="POST">
            <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded">Delete</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
</div>

</body>
</html>
